{
  "build": {
    "dockerfile": "Dockerfile.github"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "localstack.cli.location": "/home/codespace/.python/current/bin/localstack"
      },
      "extensions": [
        "amazonwebservices.aws-toolkit-vscode",
        "localstack.localstack",
        "hashicorp.terraform"
      ]
    },
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    }
  },
  "postStartCommand": "bash ./00-setup/setup.sh"
}
